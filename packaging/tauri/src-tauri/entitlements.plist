<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Required: Vamp plugins live in Contents/Resources/vamp/ (outside
       Contents/MacOS/), so library validation must be disabled for them
       to load via dlopen. See research.md R4. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>

  <!-- Torch, numba, and other JIT backends allocate executable memory
       at runtime. Without this, the process is killed by hardened
       runtime on the first JIT call. -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.allow-jit</key>
  <true/>

  <!-- User-selected files via the native Open dialog. -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>

  <!-- Downloads folder is allowed read/write so the demucs model cache
       and any .xsq exports to Downloads work without extra prompts. -->
  <key>com.apple.security.files.downloads.read-write</key>
  <true/>
</dict>
</plist>
