{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "XLight",
  "version": "0.1.0",
  "identifier": "com.xlight.autosequencer",
  "build": {
    "beforeDevCommand": "cd ../../src/review/frontend && npm run dev",
    "beforeBuildCommand": "cd ../../src/review/frontend && npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../src/review/frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "XLight",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "resources": {
      "../../pyinstaller/plugins/vamp": "vamp",
      "binaries/backend-aarch64-apple-darwin": "backend",
      "packaging-manifest.json": "packaging-manifest.json"
    },
    "macOS": {
      "entitlements": "./entitlements.plist",
      "minimumSystemVersion": "12.0",
      "hardenedRuntime": true,
      "signingIdentity": null,
      "providerShortName": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
