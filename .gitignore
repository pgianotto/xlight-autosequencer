# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
.venv-vamp/
venv/
env/
dist/
build/
# Exception: frontend pre-built SPA — committed so pip install works without Node
!src/review/frontend/dist/
*.egg-info/
.eggs/

# Testing
.pytest_cache/
.coverage
htmlcov/
*.xml

# Stem cache directories (generated by --stems flag)
.stems/

# Generated analysis files (don't commit user song data)
*_analysis.json
*_selected.json
*_top*.json

# Audio files (don't commit user songs; fixtures are generated)
*.mp3
*.mp4
*.wav
*.flac
# Exception: keep fixture generation script output notes
!tests/fixtures/README.md
!tests/fixtures/*.json
!tests/fixtures/**/*.xml

# Generated hierarchy output inside fixture dirs
tests/fixtures/**/*_hierarchy.json
tests/fixtures/**/*.xtiming
tests/fixtures/**/stems/

# Generated sequence output (don't commit user song data)
generated_sequences/
*.xsq
*.fseq
*.xbkp
# …but do commit test fixture .xsq files (goldens for regression gates).
!tests/fixtures/**/*.xsq

# Local working/scratch/song directories (user song analysis output)
analysis/
highway/
01_-_Highway_to_Hell/
joy_to_the_world/
mad_russian_christmas/

# macOS
.DS_Store

# Editor
.vscode/
.idea/
*.swp
*.swo

# Env
.env
.env.*

# Claude Code local state (per-user tooling)
.claude/

# OpenWolf — ignore transient runtime state only; team-shared docs/config stay tracked
.wolf/memory.md
.wolf/cron-state.json
.wolf/daemon.log
.wolf/designqc-report.json
.wolf/designqc-captures/
.wolf/suggestions.json
.wolf/token-ledger.json

# User song data (audio, analysis, generated sequences)
songs/
