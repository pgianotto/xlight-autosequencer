# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
.venv-vamp/
venv/
env/
dist/
build/
*.egg-info/
.eggs/

# Testing
.pytest_cache/
.coverage
htmlcov/
*.xml

# Stem cache directories (generated by --stems flag)
.stems/

# Generated analysis files (don't commit user song data)
*_analysis.json
*_selected.json
*_top*.json

# Per-song _story.json history archives (auto-rotated, see src/story/builder.py)
*_story.history/

# Audio files (don't commit user songs; fixtures are generated)
*.mp3
*.mp4
*.wav
*.flac
# Exception: keep fixture generation script output notes
!tests/fixtures/README.md
!tests/fixtures/*.json
!tests/fixtures/**/*.xml

# Generated hierarchy output inside fixture dirs
tests/fixtures/**/*_hierarchy.json
tests/fixtures/**/*.xtiming
tests/fixtures/**/stems/

# Generated sequence output (don't commit user song data)
generated_sequences/
*.xsq
*.fseq
*.xbkp
# …but do commit test fixture .xsq files (goldens for regression gates).
!tests/fixtures/**/*.xsq
!tests/evaluation/fixtures/**/*.xsq

# Local working/scratch/song directories (user song analysis output)
analysis/
highway/
01_-_Highway_to_Hell/
joy_to_the_world/
mad_russian_christmas/

# macOS
.DS_Store

# Editor
.vscode/
.idea/
*.swp
*.swo

# Env
.env
.env.*

# Claude Code local state (per-user tooling)
.claude/

# OpenWolf — ignore transient runtime state only; team-shared docs/config stay tracked
.wolf/memory.md
.wolf/cron-state.json
.wolf/daemon.log
.wolf/designqc-report.json
.wolf/designqc-captures/
.wolf/suggestions.json
.wolf/token-ledger.json

# User song data (audio, analysis, generated sequences)
songs/

# Host-side worktree checkouts (e.g. /Users/rob/.../xlight-autosequencer/.worktrees/*
# mounted into the devcontainer as ./.worktrees/*). Never tracked — worktrees
# manage their own git state.
.worktrees/

# Diagnostic script output (boundary confidence maps, QM segmenter sweeps,
# self-similarity matrices). Regenerated by scripts/ — not source of truth.
docs/bcm/
docs/qm_sweep/
docs/ssm/

# Diagnostic screenshots from tests/ui/flows/test_screenshot_all_timelines.py — opt-in via -m screenshot_all
tests/golden/timeline-screenshots/

# Microscope per-run outputs (regenerated locally)
microscope-out/
microscope-out-*/

# Render-panel harness outputs (regenerated locally)
render-out/

docs/arch_sequencing_corpus/_generated/
